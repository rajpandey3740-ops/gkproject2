# Backend Environment Variables (for Railway deployment)

# Server Configuration
PORT=3001
NODE_ENV=production

# MongoDB Configuration (Optional - app works with fallback data if not provided)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/gkshop?retryWrites=true&w=majority&appName=Cluster0&authSource=admin

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Firebase Admin SDK (Download from Firebase Console)
# FIREBASE_PROJECT_ID=gk-store-a3365
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@gk-store-a3365.iam.gserviceaccount.com

# Twilio Configuration (for OTP SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Owner Credentials
OWNER_PHONE=owner-phone-number
OWNER_PASSWORD=owner-password-here

# Development Mode (set to "true" to enable dev mode OTP)
VITE_DEV_MODE=false
